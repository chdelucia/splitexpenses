/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "module": "CommonJs",
    "outDir": "./out-tsc/spec",
    "types": ["jest", "node", "jasmine"],
    "paths": {
      "@angular/core/testing": ["node_modules/@angular/core/types/testing.d.ts"],
      "@angular/core/rxjs-interop": ["node_modules/@angular/core/types/rxjs-interop.d.ts"],
      "@angular/common/testing": ["node_modules/@angular/common/types/testing.d.ts"],
      "@angular/common/http/testing": ["node_modules/@angular/common/types/http-testing.d.ts"],
      "@angular/common/http": ["node_modules/@angular/common/types/http.d.ts"],
      "@angular/router/testing": ["node_modules/@angular/router/types/testing.d.ts"],
      "@angular/platform-browser/animations": ["node_modules/@angular/platform-browser/types/animations.d.ts"],
      "@angular/material/*": ["node_modules/@angular/material/types/*.d.ts"],
      "@ngrx/store/testing": ["node_modules/@ngrx/store/types/ngrx-store-testing.d.ts"],
      "@core/*": ["src/app/core/*"],
      "@debts/*": ["src/app/debts/*"],
      "@expenses/*": ["src/app/expenses/*"],
      "@forecast/*": ["src/app/forecast/*"],
      "@settings/*": ["src/app/settings/*"],
      "@shared/*": ["src/app/shared/*"],
      "@state/*": ["src/app/state/*"],
      "@stats/*": ["src/app/stats/*"],
      "@users/*": ["src/app/users/*"],
      "@weather/*": ["src/app/weather/*"],
      "@env/*": ["src/environments/*"]
    }
  },
  "include": ["src/**/*.spec.ts", "src/**/*.d.ts", "setup-jest.ts", "node_modules/@angular/localize/types/localize.d.ts"]
}
