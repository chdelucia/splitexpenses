{
  "name": "splitexpenses",
  "version": "1.5.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:en": "ng serve --configuration=en",
    "build": "ng build",
    "build:translation": "ng build --configuration production --base-href='https://chdelucia.github.io/splitexpenses/' --localize",
    "deploy:pro": "npx angular-cli-ghpages --dir=dist",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "ng test --watch",
    "sonar": "sonar-scanner",
    "lint": "ng lint",
    "update-hooks": "simple-git-hooks",
    "pre-commit": "",
    "pre-push": "",
    "e2e": "ng e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:firefox": "cypress run --browser firefox",
    "prettier:write": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "chart.js": "^4.5.1",
    "ng2-charts": "^10.0.0",
    "ngx-skeleton-loader": "^12.0.0",
    "rxjs": "7.8.2",
    "tslib": "^2.6.2",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.6",
    "@angular-eslint/builder": "21.3.1",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/schematics": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/cli": "21.2.6",
    "@angular/compiler-cli": "^21.2.4",
    "@angular/localize": "21.2.6",
    "@compodoc/compodoc": "1.2.1",
    "@cypress/schematic": "5.0.0",
    "@ngrx/eslint-plugin": "21.1.0",
    "@ngrx/schematics": "21.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cypress": "^15.13.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^3.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "simple-git-hooks": "^2.13.1",
    "sonar-scanner": "^3.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,html}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*spec.ts": [
      "jest"
    ],
    "*.scss": [
      "prettier --write"
    ]
  }
}
